---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog');
posts.sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
const latestPosts = posts.slice(0, 6);
const featuredPost = posts[0]; // 最新一篇文章作为精选
const categories = [...new Set(posts.map(p => p.data.category))];
---

<Layout title="异宠指南" description="中国第一个异宠新手系统化饲养指南——守宫、玉米蛇、鬃狮蜥、角蛙全面饲养知识。从零开始，科学饲养。">
  <!-- Hero Section -->
  <section class="hero">
    <div class="hero-inner">
      <p class="hero-eyebrow">新手饲养指南</p>
      <h1>从零开始<br/>科学养异宠</h1>
      <p class="hero-subtitle">
        守宫、玉米蛇、鬃狮蜥、角蛙——每个品种都有完整的饲养框架。<br/>
        不再依赖碎片化的贴吧信息，这里有你需要的全部。
      </p>
      <div class="hero-actions">
        <a href="/blog/" class="btn-primary">浏览全部文章</a>
        <a href="/about/" class="btn-secondary">了解我们</a>
      </div>
    </div>
  </section>

  <!-- Featured Article -->
  {featuredPost && (
    <section class="featured">
      <div class="section-header">
        <h2>精选文章</h2>
        <p>最新深度内容，先睹为快</p>
      </div>
      <article class="featured-card">
        <div class="featured-content">
          <span class="card-category">{featuredPost.data.category}</span>
          <h3><a href={`/blog/${featuredPost.slug}/`}>{featuredPost.data.title}</a></h3>
          <p>{featuredPost.data.description}</p>
          <div class="card-meta">
            <time datetime={featuredPost.data.pubDate.toISOString()}>
              {featuredPost.data.pubDate.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' })}
            </time>
          </div>
        </div>
      </article>
    </section>
  )}

  <!-- Categories -->
  <section class="categories">
    <div class="section-header">
      <h2>饲养主题</h2>
      <p>按主题浏览，找到你需要的知识</p>
    </div>
    <div class="category-grid">
      <a href="/blog/?category=新手指南" class="category-card">
        <span class="category-icon">📖</span>
        <h3>新手指南</h3>
        <p>从零开始的完整饲养教程</p>
      </a>
      <a href="/blog/?category=装备选购" class="category-card">
        <span class="category-icon">🛒</span>
        <h3>装备选购</h3>
        <p>饲养箱、加热、照明设备横评</p>
      </a>
      <a href="/blog/?category=技术教程" class="category-card">
        <span class="category-icon">🔧</span>
        <h3>技术教程</h3>
        <p>温控、湿度、环境搭建</p>
      </a>
      <a href="/blog/?category=疾病处理" class="category-card">
        <span class="category-icon">🏥</span>
        <h3>疾病处理</h3>
        <p>症状识别与处理方法</p>
      </a>
    </div>
  </section>

  <!-- Latest Articles -->
  <section class="latest">
    <div class="section-header">
      <h2>最新文章</h2>
      <p>持续更新中，收藏不迷路</p>
    </div>
    <div class="article-grid">
      {latestPosts.map(post => (
        <article class="article-card">
          {post.data.heroImage && (
            <a href={`/blog/${post.slug}/`} class="card-image">
              <img src={post.data.heroImage} alt={post.data.title} loading="lazy" width="600" height="315" />
            </a>
          )}
          <div class="card-body">
            <span class="card-category">{post.data.category}</span>
            <h3><a href={`/blog/${post.slug}/`}>{post.data.title}</a></h3>
            <p>{post.data.description}</p>
            <time datetime={post.data.pubDate.toISOString()}>
              {post.data.pubDate.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' })}
            </time>
          </div>
        </article>
      ))}
    </div>
    <div class="latest-cta">
      <a href="/blog/" class="btn-outline">查看全部文章 →</a>
    </div>
  </section>

  <!-- Newsletter Signup -->
  <section class="newsletter">
    <div class="newsletter-inner">
      <h2>订阅更新</h2>
      <p>新文章发布时第一时间收到通知，不定时分享饲养小贴士</p>
      <form class="newsletter-form" action="#" method="POST">
        <input type="email" placeholder="your@email.com" required />
        <button type="submit">订阅</button>
      </form>
      <p class="newsletter-note">无需邮箱验证，零骚扰承诺</p>
    </div>
  </section>
</Layout>

<style>
  /* ===== Hero ===== */
  .hero {
    background: linear-gradient(135deg, var(--green-500) 0%, var(--green-700) 100%);
    color: white;
    padding: 5rem 1.5rem 4rem;
    text-align: center;
  }

  .hero-inner {
    max-width: 680px;
    margin: 0 auto;
  }

  .hero-eyebrow {
    font-size: 0.85rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    opacity: 0.8;
    margin-bottom: 1rem;
  }

  .hero h1 {
    font-family: var(--font-serif);
    font-size: 2.8rem;
    font-weight: 700;
    line-height: 1.2;
    margin-bottom: 1.25rem;
    color: white;
  }

  .hero-subtitle {
    font-size: 1.1rem;
    line-height: 1.8;
    opacity: 0.9;
    margin-bottom: 2rem;
    color: white;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .btn-primary {
    display: inline-block;
    background: white;
    color: var(--green-700);
    padding: 0.8rem 2rem;
    border-radius: var(--radius-md);
    font-weight: 600;
    font-size: 1rem;
    transition: transform 0.15s, box-shadow 0.15s;
  }

  .btn-primary:hover {
    transform: translateY(-1px);
    box-shadow: 0 4px 16px rgba(0,0,0,0.15);
    color: var(--green-700);
  }

  .btn-secondary {
    display: inline-block;
    background: rgba(255,255,255,0.15);
    color: white;
    padding: 0.8rem 2rem;
    border-radius: var(--radius-md);
    font-weight: 500;
    font-size: 1rem;
    border: 1px solid rgba(255,255,255,0.3);
    transition: background 0.15s;
  }

  .btn-secondary:hover {
    background: rgba(255,255,255,0.25);
    color: white;
  }

  /* ===== Section Shared ===== */
  .section-header {
    text-align: center;
    margin-bottom: 2.5rem;
  }

  .section-header h2 {
    font-size: 1.75rem;
    margin-bottom: 0.5rem;
  }

  .section-header p {
    color: var(--color-text-secondary);
    font-size: 1rem;
  }

  /* ===== Featured ===== */
  .featured {
    max-width: var(--max-width-wide);
    margin: 0 auto;
    padding: 4rem 1.5rem;
  }

  .featured-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: 2rem;
    transition: box-shadow 0.2s;
  }

  .featured-card:hover {
    box-shadow: var(--shadow-lg);
  }

  .featured-content .card-category {
    font-size: 0.8rem;
    color: var(--color-accent);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .featured-content h3 {
    font-size: 1.5rem;
    margin: 0.75rem 0;
    line-height: 1.3;
  }

  .featured-content h3 a {
    color: var(--color-text);
  }

  .featured-content h3 a:hover {
    color: var(--color-primary);
  }

  .featured-content p {
    color: var(--color-text-secondary);
    font-size: 1rem;
    margin-bottom: 1rem;
  }

  .card-meta {
    font-size: 0.85rem;
    color: var(--color-text-muted);
  }

  /* ===== Categories ===== */
  .categories {
    max-width: var(--max-width-wide);
    margin: 0 auto;
    padding: 4rem 1.5rem;
    background: var(--gray-100);
  }

  .category-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1rem;
  }

  .category-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: 1.5rem;
    text-align: center;
    transition: box-shadow 0.2s, transform 0.15s;
  }

  .category-card:hover {
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
    color: inherit;
  }

  .category-icon {
    font-size: 2rem;
    display: block;
    margin-bottom: 0.75rem;
  }

  .category-card h3 {
    font-family: var(--font-sans);
    font-size: 1rem;
    font-weight: 600;
    margin-bottom: 0.5rem;
    color: var(--color-text);
  }

  .category-card p {
    font-size: 0.85rem;
    color: var(--color-text-secondary);
    margin-bottom: 0;
  }

  /* ===== Latest Articles ===== */
  .latest {
    max-width: var(--max-width-wide);
    margin: 0 auto;
    padding: 4rem 1.5rem;
  }

  .article-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.5rem;
  }

  .article-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    overflow: hidden;
    transition: box-shadow 0.2s, transform 0.15s;
  }

  .article-card:hover {
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
  }

  .card-body {
    padding: 1.5rem;
  }

  .card-body .card-category {
    font-size: 0.75rem;
    color: var(--color-accent);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .card-body h3 {
    font-size: 1.1rem;
    margin: 0.5rem 0;
    line-height: 1.4;
  }

  .card-body h3 a {
    color: var(--color-text);
  }

  .card-body h3 a:hover {
    color: var(--color-primary);
  }

  .card-body p {
    font-size: 0.9rem;
    color: var(--color-text-secondary);
    margin-bottom: 1rem;
    line-height: 1.6;
  }

  .card-body time {
    font-size: 0.8rem;
    color: var(--color-text-muted);
  }

  .latest-cta {
    text-align: center;
    margin-top: 2.5rem;
  }

  .btn-outline {
    display: inline-block;
    border: 2px solid var(--color-primary);
    color: var(--color-primary);
    padding: 0.7rem 2rem;
    border-radius: var(--radius-md);
    font-weight: 600;
    font-size: 0.95rem;
    transition: background 0.15s, color 0.15s;
  }

  .btn-outline:hover {
    background: var(--color-primary);
    color: white;
  }

  /* ===== Newsletter ===== */
  .newsletter {
    background: var(--green-50);
    padding: 4rem 1.5rem;
  }

  .newsletter-inner {
    max-width: 500px;
    margin: 0 auto;
    text-align: center;
  }

  .newsletter h2 {
    font-size: 1.5rem;
    margin-bottom: 0.5rem;
  }

  .newsletter p {
    color: var(--color-text-secondary);
    margin-bottom: 1.5rem;
  }

  .newsletter-form {
    display: flex;
    gap: 0.75rem;
    max-width: 400px;
    margin: 0 auto 1rem;
  }

  .newsletter-form input {
    flex: 1;
    padding: 0.7rem 1rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    font-size: 0.95rem;
    font-family: var(--font-sans);
  }

  .newsletter-form input:focus {
    outline: none;
    border-color: var(--color-primary);
    box-shadow: 0 0 0 3px var(--green-100);
  }

  .newsletter-form button {
    background: var(--color-primary);
    color: white;
    border: none;
    padding: 0.7rem 1.5rem;
    border-radius: var(--radius-sm);
    font-weight: 600;
    font-size: 0.95rem;
    cursor: pointer;
    transition: background 0.15s;
  }

  .newsletter-form button:hover {
    background: var(--color-primary-dark);
  }

  .newsletter-note {
    font-size: 0.8rem;
    color: var(--color-text-muted);
  }

  /* ===== Responsive ===== */
  @media (max-width: 768px) {
    .hero {
      padding: 3rem 1.25rem 3rem;
    }

    .hero h1 {
      font-size: 2rem;
    }

    .hero-subtitle {
      font-size: 1rem;
    }

    .featured,
    .categories,
    .latest,
    .newsletter {
      padding: 3rem 1.25rem;
    }

    .newsletter-form {
      flex-direction: column;
    }
  }
</style>
