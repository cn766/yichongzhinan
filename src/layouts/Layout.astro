---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

// 从 Astro.props 获取页面级 meta（由子页面传入）
const { title = '异宠指南', description = '中国第一个异宠新手系统化饲养指南——守宫、玉米蛇、鬃狮蜥、角蛙全面饲养知识' } = Astro.props;
const siteUrl = 'https://yichongzhinan.com';
const pageUrl = new URL(Astro.url.pathname, siteUrl).toString();

// Google Analytics & Search Console（通过 Vercel 环境变量注入，本地开发时为空）
const gaId = import.meta.env.PUBLIC_GA_ID;
const gscCode = import.meta.env.PUBLIC_GSC_CODE;

// 百度统计（通过 Vercel 环境变量注入）
const baiduHmId = import.meta.env.PUBLIC_BAIDU_HM_ID || '1bcb13a8a510610b9e76f28f4db0447d';
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+SC:wght@400;500;600&family=Noto+Serif+SC:wght@400;600;700&display=swap" rel="stylesheet" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={pageUrl} />

    <!-- Google Search Console 验证（部署后在 Vercel 设置 PUBLIC_GSC_CODE） -->
    {gscCode && <meta name="google-site-verification" content={gscCode} />}

    <!-- Google Analytics (GA4) -->
    {gaId && (
      <>
        <script async src={`https://www.googletagmanager.com/gtag/js?id=${gaId}`}></script>
        <script>
          {`window.dataLayer = window.dataLayer || [];
          function gtag(){dataLayer.push(arguments);}
          gtag('js', new Date());
          gtag('config', '${gaId}');`}
        </script>
      </>
    )}

    <!-- 百度统计 -->
    <script>
      var _hmt = _hmt || [];
      (function() {
        var hm = document.createElement("script");
        hm.src = "https://hm.baidu.com/hm.js?{baiduHmId}";
        var s = document.getElementsByTagName("script")[0];
        s.parentNode.insertBefore(hm, s);
      })();
    </script>

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={pageUrl} />
    <meta property="og:site_name" content="异宠指南" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
